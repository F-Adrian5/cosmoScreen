<Window x:Class="cosmoScreen.login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Width="500"
        Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Background="#FF2C2D31">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cím -->
        <Label Grid.Row="0"
               Content="Bejelentkezés"
               HorizontalAlignment="Center"
               Margin="0,20"
               FontSize="30"
               FontStyle="Italic"
               Foreground="#FFA09D9D"/>

        <!-- Form -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="300">

            <Label Content="Email:"
                   FontSize="16"
                   Foreground="#FF9DCC3B"/>

            <TextBox Name="loginE_input"
                     Height="35"
                     Margin="0,5,0,15"/>

            <Label Content="Jelszó:"
                   FontSize="16"
                   Foreground="#FF9DCC3B"/>

            <PasswordBox Name="loginP_input"
                         Height="35"
                         Margin="0,5,0,20"/>

            <Button Name="login_btn"
                    Content="Bejelentkezés"
                    Height="50"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#FF9DCC3B"
                    Background="Black"
                    BorderBrush="Black"
                    Click="login_btn_Click"/>
        </StackPanel>

        <!-- Alsó margó (opcionális) -->
        <Border Grid.Row="2" Height="20"/>
    </Grid>
</Window>
