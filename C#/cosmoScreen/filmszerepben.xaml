<Window x:Class="cosmoScreen.filmszerepben"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cosmoScreen"
        mc:Ignorable="d"
        Title="filmszerepben" Height="650" Width="976">
    <Grid Background="#FF2C2D31">
        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom buttons -->
        </Grid.RowDefinitions>

        <!-- MENU -->
        <Menu Grid.Row="0"
              FontSize="20"
              FontWeight="Bold"
              Background="Black"
              Foreground="LightGray">

            <MenuItem Header="Filmek" Click="films_menuItem_Click"/>
            <MenuItem Header="Büfé" Click="buffet_menuItem_Click"/>
            <MenuItem Header="Színészek" Click="actor_menuItem_Click"/>
            <MenuItem Header="Felhasználók" Click="user_menuItem_Click"/>
            <MenuItem Header="Film Szerepben" Foreground="#FF9DCC3B"/>
        </Menu>

        <!-- Right side button -->
        <Button Content="Kijelentkezés"
                FontSize="18"
                Name="logout_btn"
                FontWeight="Bold"
                Foreground="White"
                Background="Black"
                BorderBrush="Transparent"
                Margin="824,0,20,5" Click="logout_btn_Click"/>

        <!-- HEADER -->
        <Label Grid.Row="1"
               Content="Film Szerepben"
               HorizontalAlignment="Center"
               FontSize="26"
               FontWeight="Bold"
               FontStyle="Italic"
               Margin="0,10" Foreground="#FFA09D9D"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT FORM -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">

                <Label Content="Film szerepen adatok"
                       FontSize="22"
                       FontWeight="Bold"
                       FontStyle="Italic"
                       Foreground="#FFA09D9D"/>

                <Label Content="Film:"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,20,0,0" Foreground="#FF9DCC3B"/>

                <ComboBox x:Name="movie_combobox" FontSize="16" ></ComboBox>

                <Label Content="Színész:"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,20,0,0" Foreground="#FF9DCC3B"/>

                <ComboBox x:Name="actor_combobox" FontSize="16" ></ComboBox>
            </StackPanel>

            <!-- DATAGRID -->
            <DataGrid x:Name="actor_in_movie_datagrid"
                      Grid.Column="2"
                      Background="White"
                      AutoGenerateColumns="True" SelectionChanged="actor_in_movie_datagrid_SelectionChanged"/>
        </Grid>

        <!-- BOTTOM BUTTON BAR -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15">

            <!-- insert btn -->
            <Button x:Name="btn_upload"
                    Content="Felvétel"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="btn_upload_Click" Foreground="#FF9DCC3B" Background="Black"/>

            <!-- edit btn -->
            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="edit_data_btn_Click" Foreground="#FF9DCC3B" Background="Black"/>

            <!-- delete btn -->
            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="delete_data_btn_Click" Foreground="#FF9DCC3B" Background="Black"/>
        </StackPanel>
    </Grid>
</Window>
