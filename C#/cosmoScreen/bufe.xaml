<Window x:Class="cosmoScreen.bufe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Büfé" Height="750" Width="976">

    <Grid Background="#FFB5C6FB">

        <!-- main rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom Buttons -->
        </Grid.RowDefinitions>

        <!-- menu -->
        <Menu Grid.Row="0" FontSize="20" FontWeight="Bold" Background="Black" Foreground="LightGray">
            <MenuItem Header="Filmek" Name="films_menuItem" Click="films_menuItem_Click"/>
            <MenuItem Header="Büfé" Name="buffet_menuItem" Foreground="#FF9DCC3B"/>
            <MenuItem Header="Színészek" Name="actor_menuItem" Click="actor_menuItem_Click"/>
            <MenuItem Header="Felhasználók" Name="user_menuItem" Click="user_menuItem_Click"/>
        </Menu>

        <!-- title -->
        <Label Grid.Row="1"
               Content="Büfé"
               HorizontalAlignment="Center"
               FontSize="26" FontWeight="Bold" FontStyle="Italic"
               Margin="0,20,0,10"/>

        <!-- main content -->
        <Grid Grid.Row="2" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- left panel -->
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <!-- datagrid -->
            </Grid.ColumnDefinitions>

            <!-- left form -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">

                <Label Content="Büfé adatok felvétele" 
                       FontSize="22"
                       FontWeight="Bold"
                       FontStyle="Italic"
                       Foreground="#FF693EE4"
                       Margin="0,0,0,20"/>

                <Label Content="Név" FontSize="16" FontWeight="Bold"/>
                <TextBox x:Name="food_name"
                         FontSize="16"
                         MaxLength="100"
                         TextChanged="InputChanged"/>

                <Label Content="Ár" FontSize="16" FontWeight="Bold" Margin="0,15,0,0"/>
                <TextBox x:Name="food_price"
                         FontSize="16"
                         MaxLength="5"
                         TextChanged="InputChanged"/>

                <Label Content="Leírás" FontSize="16" FontWeight="Bold" Margin="0,15,0,0"/>
                <TextBox x:Name="food_description"
                         FontSize="16"
                         MaxLength="250"
                         TextWrapping="Wrap"
                         Height="80"
                         TextChanged="InputChanged"/>

                <Label Content="Kép URL" FontSize="16" FontWeight="Bold" Margin="0,15,0,0"/>
                <TextBox x:Name="food_image_url"
                         FontSize="16"
                         MaxLength="250"
                         TextChanged="InputChanged"/>

                <Button x:Name="btn_upload"
                        Content="Felvétel"
                        Height="60"
                        Margin="0,20,0,0"
                        FontWeight="Bold" FontSize="24"
                        IsEnabled="False"
                        Click="btn_upload_Click"/>
            </StackPanel>

            <!-- datagrid -->
            <DataGrid Grid.Column="2"
                      x:Name="buffet_datagrid"
                      AutoGenerateColumns="True"
                      Background="White"
                      VerticalAlignment="Stretch"
                      SelectionChanged="buffet_datagrid_SelectionChanged"/>
        </Grid>

        <!-- Bottom btns -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15">


            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="180" Height="60"
                    Margin="10"
                    FontWeight="Bold" FontSize="24"
                    IsEnabled="False"
                    Click="edit_data_btn_Click"/>

            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="180" Height="60"
                    Margin="10"
                    FontWeight="Bold" FontSize="24"
                    IsEnabled="False"
                    Click="delete_data_btn_Click"/>

        </StackPanel>
    </Grid>
</Window>