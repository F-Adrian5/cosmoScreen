<Window x:Class="cosmoScreen.bufe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cosmoScreen"
        mc:Ignorable="d"
        Title="Büfé" Height="650" Width="976">
    <Grid Background="#FFB5C6FB">
        <Menu VerticalAlignment="Top" FontSize="20" FontWeight="Bold" Foreground="Black" Background="Black">
            <Image Source="/mini-logo.PNG" Width="50px" Height="50px"></Image>
            <MenuItem Name="films_menuItem" Header="Filmek" FontSize="20" FontWeight="Bold" Click="films_menuItem_Click" Foreground="#FFDCD7D7"/>
            <MenuItem Name="buffet_menuItem" Header="Büfé" Foreground="#FF9DCC3B"/>
            <MenuItem Name="actor_menuItem" Header="Színészek" Click="actor_menuItem_Click" Foreground="#FFDCD7D7"/>
        </Menu>
        <Label Content="Név" HorizontalAlignment="Left" Margin="26,166,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"/>
        <TextBox x:Name="food_name" TextChanged="InputChanged" HorizontalAlignment="Left" Margin="131,174,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Label Content="Ár" HorizontalAlignment="Left" Margin="26,209,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <TextBox x:Name="food_price" TextChanged="InputChanged" HorizontalAlignment="Left" Margin="131,217,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Label Content="Leírás" HorizontalAlignment="Left" Margin="26,248,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <TextBox x:Name="food_description" TextChanged="InputChanged" HorizontalAlignment="Left" Margin="32,284,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="219" FontSize="16" Height="84"/>
        <Label Content="Kép URL" HorizontalAlignment="Left" Margin="26,373,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <TextBox x:Name="food_image_url" TextChanged="InputChanged" HorizontalAlignment="Left" Margin="131,381,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Button x:Name="btn_upload" IsEnabled="False" Content="Felvétel" HorizontalAlignment="Left" Margin="46,447,0,0" VerticalAlignment="Top" Height="63" Width="182" FontSize="24" FontWeight="Bold" Click="btn_upload_Click"/>
        <Label Content="Büfé" HorizontalAlignment="Center" Margin="0,57,0,0" VerticalAlignment="Top" Height="41" Width="162" FontSize="26" FontWeight="Bold" FontStyle="Italic"/>
        <DataGrid x:Name="buffet_datagrid" HorizontalAlignment="Left" Height="396" Margin="265,0,0,0" VerticalAlignment="Center" Width="673" d:ItemsSource="{d:SampleData ItemCount=5}" Background="{x:Null}"/>
        <Button x:Name="get_data_btn" Content="Lekérdez" HorizontalAlignment="Left" Margin="544,521,0,0" VerticalAlignment="Top" FontSize="24" Height="63" Width="182" FontWeight="Bold" Click="get_data_btn_Click"/>
        <Label Content="Büfé adatok felvétele" HorizontalAlignment="Left" Margin="14,114,0,0" VerticalAlignment="Top" Height="38" Width="274" FontSize="22" FontStyle="Italic" FontWeight="Bold" Foreground="#FF693EE4"/>
    </Grid>
</Window>
