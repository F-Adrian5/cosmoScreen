<Window x:Class="cosmoScreen.bufe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Büfé"
        Height="750"
        Width="976">

    <Grid Background="#FF2C2D31">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom buttons -->
        </Grid.RowDefinitions>

        <!-- MENU -->
        <Menu Grid.Row="0"
              FontSize="20"
              FontWeight="Bold"
              Background="Black"
              Foreground="LightGray">

            <MenuItem Header="Filmek"
                      Name="films_menuItem"
                      Click="films_menuItem_Click"/>

            <MenuItem Header="Büfé"
                      Name="buffet_menuItem"
                      Foreground="#FF9DCC3B"/>

            <MenuItem Header="Színészek"
                      Name="actor_menuItem"
                      Click="actor_menuItem_Click"/>

            <MenuItem Header="Felhasználók"
                      Name="user_menuItem"
                      Click="user_menuItem_Click"/>
        </Menu>

        <!-- Right side button -->
        <Button
            Content="Kijelentkezés"
            Name="logout_btn"
            FontSize="18"
            FontWeight="Bold"
            Foreground="White"
            Background="Black"
            BorderBrush="Transparent"
            Margin="824,0,20,0" Height="28" VerticalAlignment="Top" Click="Button_Click"/>
		
        <!-- TITLE -->
        <Label Grid.Row="1"
               Content="Büfé"
               HorizontalAlignment="Center"
               FontSize="26"
               FontWeight="Bold"
               FontStyle="Italic"
               Margin="0,20,0,10" Foreground="#FFA09D9D"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Left panel -->
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <!-- DataGrid -->
            </Grid.ColumnDefinitions>

            <!-- LEFT FORM -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top">

                <Label Content="Büfé adatok felvétele"
                       FontSize="22"
                       FontWeight="Bold"
                       FontStyle="Italic"
                       Foreground="#FFA09D9D"
                       Margin="0,0,0,20"/>

                <Label Content="Név"
                       FontSize="16"
                       FontWeight="Bold" Foreground="#FF9DCC3B"/>
                <TextBox x:Name="food_name"
                         FontSize="16"
                         MaxLength="100"
                         TextChanged="InputChanged"/>

                <Label Content="Ár"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,15,0,0" Foreground="#FF9DCC3B"/>
                <TextBox x:Name="food_price"
                         FontSize="16"
                         MaxLength="5"
                         TextChanged="InputChanged"/>

                <Label Content="Leírás"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,15,0,0" Foreground="#FF9DCC3B"/>
                <TextBox x:Name="food_description"
                         FontSize="16"
                         MaxLength="250"
                         TextWrapping="Wrap"
                         Height="80"
                         TextChanged="InputChanged"/>

                <Label Content="Kép URL"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,15,0,0" Foreground="#FF9DCC3B"/>
                <TextBox x:Name="food_image_url"
                         FontSize="16"
                         MaxLength="250"
                         TextChanged="InputChanged"/>

            </StackPanel>

            <!-- DATAGRID -->
            <DataGrid Grid.Column="2"
                      x:Name="buffet_datagrid"
                      AutoGenerateColumns="True"
                      Background="White"
                      VerticalAlignment="Stretch"
                      SelectionChanged="buffet_datagrid_SelectionChanged"/>
        </Grid>

        <!-- BOTTOM BUTTONS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15">

            <!-- insert btn -->
            <Button x:Name="btn_upload"
                    Content="Felvétel"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontWeight="Bold"
                    FontSize="24"
                    IsEnabled="False"
                    Click="btn_upload_Click" Background="Black" Foreground="#FF9DCC3B"/>

            <!-- Edit btn -->
            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontWeight="Bold"
                    FontSize="24"
                    IsEnabled="False"
                    Click="edit_data_btn_Click" Background="Black" Foreground="#FF9DCC3B"/>

            <!-- Delete btn -->
            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontWeight="Bold"
                    FontSize="24"
                    IsEnabled="False"
                    Click="delete_data_btn_Click" Background="Black" Foreground="#FF9DCC3B"/>

        </StackPanel>
    </Grid>
</Window>