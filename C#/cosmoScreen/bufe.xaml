<Window x:Class="cosmoScreen.bufe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cosmoScreen"
        mc:Ignorable="d"
        Title="Büfé" Height="629" Width="976">
    <Grid Background="#FF2C80C1">
        <Menu VerticalAlignment="Top" FontSize="20" FontWeight="Bold" Foreground="Black" Background="#FF949494">
            <MenuItem Name="films_menuItem" Header="Filmek" FontSize="20" FontWeight="Bold" Click="films_menuItem_Click"/>
            <MenuItem Name="buffet_menuItem" Header="Büfé" Foreground="#FF9DCC3B"/>
            <MenuItem Name="actor_menuItem" Header="Színészek" Click="actor_menuItem_Click"/>
        </Menu>
        <Label Content="Név" HorizontalAlignment="Left" Margin="27,92,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"/>
        <TextBox x:Name="food_name" HorizontalAlignment="Left" Margin="132,100,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Label Content="Ár" HorizontalAlignment="Left" Margin="27,135,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <TextBox x:Name="food_price" HorizontalAlignment="Left" Margin="132,143,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Label Content="Leírás" HorizontalAlignment="Left" Margin="27,174,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <TextBox x:Name="food_description" HorizontalAlignment="Left" Margin="33,210,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="219" FontSize="16" Height="84"/>
        <Label Content="Kép URL" HorizontalAlignment="Left" Margin="27,299,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <TextBox x:Name="food_image_url" HorizontalAlignment="Left" Margin="132,307,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Button x:Name="btn_upload" Content="Felvétel" HorizontalAlignment="Left" Margin="47,373,0,0" VerticalAlignment="Top" Height="63" Width="182" FontSize="24" FontWeight="Bold"/>
        <Label Content="Büfé" HorizontalAlignment="Center" Margin="0,34,0,0" VerticalAlignment="Top" Height="37" Width="162" FontSize="26" FontWeight="Bold" FontStyle="Italic"/>
        <DataGrid x:Name="buffet_datagrid" HorizontalAlignment="Left" Height="410" Margin="280,89,0,0" VerticalAlignment="Top" Width="673" d:ItemsSource="{d:SampleData ItemCount=5}" Background="{x:Null}"/>
        <Button x:Name="get_data_btn" Content="Lekérdez" HorizontalAlignment="Left" Margin="544,521,0,0" VerticalAlignment="Top" FontSize="24" Height="63" Width="182" FontWeight="Bold"/>
        <Label Content="Büfé adatok felvétele" HorizontalAlignment="Left" Margin="16,52,0,0" VerticalAlignment="Top" Height="38" Width="274" FontSize="22" FontStyle="Italic" FontWeight="Bold" Foreground="#FFAB0F0F"/>
    </Grid>
</Window>
