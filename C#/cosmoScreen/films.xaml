<Window x:Class="cosmoScreen.films"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filmek" Height="900" Width="1000">

    <Grid Background="#FFB5C6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom Buttons -->
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0"
              FontSize="20"
              FontWeight="Bold"
              Background="Black"
              Foreground="LightGray">
            <MenuItem Header="Filmek" Name="films_menuItem" Foreground="#FF9DCC3B"/>
            <MenuItem Header="Büfé" Name="buffet_menuItem" Click="buffet_menuItem_Click"/>
            <MenuItem Header="Színészek" Name="actor_menuItem" Click="actor_menuItem_Click"/>
        </Menu>

        <!-- title -->
        <Label Grid.Row="1"
               Content="Film felvétel"
               HorizontalAlignment="Center"
               FontSize="26"
               FontWeight="Bold"
               FontStyle="Italic"
               Margin="0,20,0,10"/>

        <!-- Main content grid-->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <!-- Left form -->
                <ColumnDefinition Width="20"/>
                <!-- spacing -->
                <ColumnDefinition Width="*"/>
                <!-- DataGrid -->
            </Grid.ColumnDefinitions>

            <!-- left form -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Label Content="Film adatok felvétele"
                           FontSize="22"
                           FontWeight="Bold"
                           FontStyle="Italic"
                           Foreground="#FF693EE4"
                           Margin="0,0,0,20"/>

                    <!-- title -->
                    <Label Content="Cím:" FontWeight="Bold" FontSize="16"/>
                    <TextBox x:Name="title_input" FontSize="16" TextChanged="InputChanged"/>

                    <!-- runtime -->
                    <Label Content="Játékidő:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <TextBox x:Name="runtime_input" FontSize="16" TextChanged="InputChanged"/>

                    <!-- director -->
                    <Label Content="Rendező:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <TextBox x:Name="director_input" FontSize="16" TextChanged="InputChanged"/>

                    <!-- studio -->
                    <Label Content="Stúdió:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <TextBox x:Name="production_input" FontSize="16" TextChanged="InputChanged"/>

                    <!-- poster URL -->
                    <Label Content="Poszter URL:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <TextBox x:Name="poster_input" FontSize="16" TextChanged="InputChanged"/>

                    <!-- trailer URL -->
                    <Label Content="Előzetes URL:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <TextBox x:Name="trailer_input" FontSize="16" TextChanged="InputChanged"/>

                    <!-- genre -->
                    <Label Content="Műfaj:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <ComboBox x:Name="genre_combobox"
                              FontSize="16"
                              SelectionChanged="InputChanged">
                        <ComboBoxItem Content="Akció"/>
                        <ComboBoxItem Content="Dráma"/>
                        <ComboBoxItem Content="Történelmi"/>
                        <ComboBoxItem Content="Horror"/>
                        <ComboBoxItem Content="Animáció"/>
                        <ComboBoxItem Content="Fantasy"/>
                        <ComboBoxItem Content="Sci-Fi"/>
                        <ComboBoxItem Content="Bűnügyi"/>
                        <ComboBoxItem Content="Thriller"/>
                    </ComboBox>

                    <!-- age -->
                    <Label Content="Korhatár:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <ComboBox x:Name="age_restriction_combobox"
                              FontSize="16"
                              SelectionChanged="InputChanged">
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="18"/>
                    </ComboBox>

                    <!-- format -->
                    <Label Content="Formátum:" FontWeight="Bold" FontSize="16" Margin="0,15,0,0"/>
                    <ComboBox x:Name="showing_in_combobox"
                              FontSize="16"
                              SelectionChanged="InputChanged">
                        <ComboBoxItem Content="IMAX"/>
                        <ComboBoxItem Content="4DX"/>
                        <ComboBoxItem Content="SCREENX"/>
                        <ComboBoxItem Content="2D"/>
                        <ComboBoxItem Content="3D"/>
                    </ComboBox>

                    <!-- releas date -->
                    <Label Content="Megjelenési dátum:"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,15,0,0"/>
                    <DatePicker x:Name="release_date_input"
                                FontSize="16"
                                SelectedDateChanged="InputChanged"/>

                    <!-- description -->
                    <Label Content="Leírás:"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,15,0,0"/>
                    <TextBox x:Name="description_input"
                             FontSize="16"
                             Height="80"
                             TextWrapping="Wrap"
                             TextChanged="InputChanged"/>

                    <!-- upload btn -->
                    <Button x:Name="btn_upload"
                            Content="Felvétel"
                            Height="60"
                            Margin="0,20,0,0"
                            FontSize="24"
                            FontWeight="Bold"
                            IsEnabled="False"
                            Click="btn_upload_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- data grid -->
            <DataGrid Grid.Column="2"
                      x:Name="movie_datagrid"
                      AutoGenerateColumns="True"
                      Background="White"
                      VerticalAlignment="Stretch"
                      SelectionChanged="movie_datagrid_SelectionChanged"/>
        </Grid>

        <!-- bottom button bar -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,20">

            <Button x:Name="get_data_btn"
                    Content="Lekérdez"
                    Width="180" Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    Click="get_data_btn_Click"/>

            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="180" Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="edit_data_btn_Click"/>

            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="180" Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="delete_data_btn_Click"/>
        </StackPanel>
    </Grid>
</Window>
