<Window x:Class="cosmoScreen.felhasznalok"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Felhasználók"
        Height="600"
        Width="900"
        MinHeight="450"
        MinWidth="800"
        Background="#FF2C2D31">

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom buttons -->
        </Grid.RowDefinitions>

        <!-- COLUMNS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <!-- Inputs -->
            <ColumnDefinition Width="3*"/>
            <!-- DataGrid -->
        </Grid.ColumnDefinitions>

        <!-- MENU -->
        <Menu Grid.Row="0"
              Grid.ColumnSpan="2"
              FontSize="20"
              FontWeight="Bold"
              Background="Black"
              Foreground="LightGray">

            <MenuItem Header="Filmek" Click="films_menuItem_Click"/>
            <MenuItem Header="Büfé" Click="buffet_menuItem_Click"/>
            <MenuItem Header="Színészek" Click="actor_menuItem_Click"/>
            <MenuItem Header="Felhasználók" Foreground="#FF9DCC3B"/>
        </Menu>

        <!-- TITLE -->
        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,10"
                    HorizontalAlignment="Center">

            <Label Content="Felhasználók"
                   FontSize="26"
                   FontWeight="Bold"
                   FontStyle="Italic" Foreground="#FFA09D9D"/>
            <Label Content="Felhasználó adatok felvétele"
                   FontSize="22"
                   FontWeight="Bold"
                   FontStyle="Italic"
                   Foreground="#FFA09D9D"/>
        </StackPanel>

        <!-- INPUTS -->
        <Grid Grid.Row="2"
              Grid.Column="0"
              Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Név:"
                   Grid.Row="0"
                   Grid.Column="0"
                   FontWeight="Bold"
                   FontSize="16"
                   VerticalAlignment="Center" Foreground="#FF9DCC3B"/>

            <TextBox x:Name="user_name_input"
                     Grid.Row="0"
                     Grid.Column="1"
                     FontSize="16"
                     MaxLength="100"
                     Margin="5"
                     TextChanged="InputChanged"/>

            <Label Content="Email:"
                   Grid.Row="1"
                   Grid.Column="0"
                   FontWeight="Bold"
                   FontSize="16"
                   VerticalAlignment="Center" Foreground="#FF9DCC3B"/>

            <TextBox x:Name="email_input"
                     Grid.Row="1"
                     Grid.Column="1"
                     FontSize="16"
                     MaxLength="150"
                     Margin="5"
                     TextChanged="InputChanged"/>

            <Label Content="Jelszó:"
                   Grid.Row="2"
                   Grid.Column="0"
                   FontWeight="Bold"
                   FontSize="16"
                   VerticalAlignment="Center" Foreground="#FF9DCC3B"/>

            <TextBox x:Name="password_input"
                     Grid.Row="2"
                     Grid.Column="1"
                     FontSize="16"
                     MaxLength="20"
                     Margin="5"
                     TextChanged="InputChanged"/>
        </Grid>

        <!-- DATAGRID -->
        <DataGrid x:Name="users_datagrid"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="15"
                  AutoGenerateColumns="True"
                  VerticalAlignment="Stretch"
                  SelectionChanged="users_datagrid_SelectionChanged"/>

        <!-- BOTTOM BUTTONS -->
        <StackPanel Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15">

            <!-- Insert -->
            <Button x:Name="btn_upload"
                    Content="Felvétel"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="22"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="btn_upload_Click" Foreground="#FF9DCC3B" Background="Black"/>

            <!-- edit btn -->
            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="22"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="edit_data_btn_Click" Foreground="#FF9DCC3B" Background="Black"/>

            <!-- delete btn -->
            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="22"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="delete_data_btn_Click" Foreground="#FF9DCC3B" Background="Black"/>
        </StackPanel>
    </Grid>
</Window>