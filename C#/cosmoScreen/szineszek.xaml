<Window x:Class="cosmoScreen.szineszek"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Színészek"
        Height="650"
        Width="976"
        Background="#FFB5C6FB">

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom buttons -->
        </Grid.RowDefinitions>

        <!-- MENU -->
        <Menu Grid.Row="0"
              FontSize="20"
              FontWeight="Bold"
              Background="Black"
              Foreground="LightGray">

            <MenuItem Header="Filmek" Click="films_menuItem_Click"/>
            <MenuItem Header="Büfé" Click="buffet_menuItem_Click"/>
            <MenuItem Header="Színészek" Foreground="#FF9DCC3B"/>
            <MenuItem Header="Felhasználók" Click="user_menuItem_Click"/>
        </Menu>

        <!-- HEADER -->
        <Label Grid.Row="1"
               Content="Színészek"
               HorizontalAlignment="Center"
               FontSize="26"
               FontWeight="Bold"
               FontStyle="Italic"
               Margin="0,10"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT FORM -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">

                <Label Content="Színész adatok"
                       FontSize="22"
                       FontWeight="Bold"
                       FontStyle="Italic"
                       Foreground="#FF693EE4"/>

                <Label Content="Teljes név:"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,20,0,0"/>

                <TextBox x:Name="actor_name_input"
                         FontSize="16"
                         MaxLength="100"
                         PreviewTextInput="NameOnly"
                         TextChanged="actor_name_input_TextChanged"/>
            </StackPanel>

            <!-- DATAGRID -->
            <DataGrid x:Name="actors_datagrid"
                      Grid.Column="2"
                      Background="White"
                      AutoGenerateColumns="True"
                      SelectionChanged="actors_datagrid_SelectionChanged"/>
        </Grid>

        <!-- BOTTOM BUTTON BAR -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15">

            <!-- insert btn -->
            <Button x:Name="btn_upload"
                    Content="Felvétel"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="btn_upload_Click"/>

            <!-- edit btn -->
            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="edit_data_btn_Click"/>

            <!-- delete btn -->
            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="180"
                    Height="60"
                    Margin="10"
                    FontSize="24"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="delete_data_btn_Click"/>
        </StackPanel>
    </Grid>
</Window>