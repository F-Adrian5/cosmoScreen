<Window x:Class="cosmoScreen.szineszek"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Színészek" Height="650" Width="976">

    <Grid Background="#FFB5C6FB">

        <!-- Main rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- menu -->
        <Menu Grid.Row="0" FontSize="20" FontWeight="Bold" Background="Black" Foreground="LightGray">
            <MenuItem Header="Filmek" Name="films_menuItem" Click="films_menuItem_Click"/>
            <MenuItem Header="Büfé" Name="buffet_menuItem" Click="buffet_menuItem_Click"/>
            <MenuItem Header="Színészek" Name="actor_menuItem" Foreground="#FF9DCC3B"/>
            <MenuItem Header="Felhasználók" Name="user_menuItem" Click="user_menuItem_Click"/>
        </Menu>

        <!-- header -->
        <Label Grid.Row="1"
               Content="Színészek"
               HorizontalAlignment="Center"
               FontSize="26" FontWeight="Bold" FontStyle="Italic"
               Margin="0,10"/>

        <!-- main content -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- form -->
                <ColumnDefinition Width="20"/>
                <!-- spacing -->
                <ColumnDefinition Width="*"/>
                <!-- datagrid -->
            </Grid.ColumnDefinitions>

            <!-- left form -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">

                <Label Content="Színész adatok felvétele" 
                       FontSize="22" FontWeight="Bold" FontStyle="Italic" Foreground="#FF693EE4"/>

                <Label Content="Teljes Neve:" FontSize="16" FontWeight="Bold" Margin="0,20,0,0"/>
                <TextBox x:Name="actor_name_input"
                         FontSize="16" 
                         TextChanged="actor_name_input_TextChanged"/>

                <Button x:Name="btn_upload"
                        Content="Felvétel"
                        Height="50"
                        FontSize="22" FontWeight="Bold"
                        Margin="0,20,0,0"
                        Click="btn_upload_Click"/>
            </StackPanel>

            <!-- data grid -->
            <DataGrid x:Name="actors_datagrid"
                      Grid.Column="2"
                      Background="White"
                      SelectionChanged="actors_datagrid_SelectionChanged"
                      AutoGenerateColumns="True"/>
        </Grid>

        <!-- button bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10">

            <Button x:Name="get_data_btn"
                    Content="Lekérdez"
                    Width="150" Height="50" FontSize="20" FontWeight="Bold"
                    Margin="10"
                    Click="get_data_btn_Click"/>

            <Button x:Name="edit_data_btn"
                    Content="Módosítás"
                    Width="150" Height="50" FontSize="20" FontWeight="Bold"
                    Margin="10"
                    IsEnabled="False"
                    Click="edit_data_btn_Click"/>

            <Button x:Name="delete_data_btn"
                    Content="Törlés"
                    Width="150" Height="50" FontSize="20" FontWeight="Bold"
                    Margin="10"
                    IsEnabled="False"
                    Click="delete_data_btn_Click"/>
        </StackPanel>

    </Grid>
</Window>